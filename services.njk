---
layout: base.njk
title: Services
activePage: services
---

<section class="hero-wrap hero-wrap-2" style="background-image: url('/images/bg_2.jpg');">
  <div class="overlay"></div>
  <div class="container">
    <div class="row no-gutters slider-text align-items-center justify-content-center">
      <div class="col-md-9 ftco-animate text-center">
        <h1 class="mb-2 bread">{{ services.heroTitle }}</h1>
        <p class="breadcrumbs"><span class="mr-2"><a href="/">Home <i class="ion-ios-arrow-forward"></i></a></span> <span>Services <i class="ion-ios-arrow-forward"></i></span></p>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section ftco-no-pb">
  <div class="container">
    <div class="row d-flex">
      <div class="col-md-5 order-md-last wrap-about align-items-stretch">
        <div class="wrap-about-border ftco-animate">
          <div class="img" style="background-image: url(/images/logo.png); border"></div>
          <div class="text">
            <h3 align="center">Get a Site Evaluation</h3>
            <p></p>
            <p align="center"><a href="/contact/" class="btn btn-primary py-3 px-4">Contact us</a></p>
          </div>
        </div>
      </div>
      <div class="col-md-7 wrap-about pr-md-4 ftco-animate">
        <h2 class="mb-4">{{ services.heading }}</h2>
        <p align="center">{{ services.intro }}</p>
        <div class="row mt-5">
          <div class="col-lg-6">
            <div class="services active text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-analysis"></span></div>
              <div class="text media-body">
                <h3>{{ services.services[0].name }}</h3>
                <p>{{ services.services[0].description }}</p>
              </div>
            </div>
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-business"></span></div>
              <div class="text media-body">
                <h3>{{ services.services[1].name }}</h3>
                <p>{{ services.services[1].description }}</p>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-search-engine"></span></div>
              <div class="text media-body">
                <h3>{{ services.services[2].name }}</h3>
                <p>{{ services.services[2].description }}</p>
              </div>
            </div>
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-handshake"></span></div>
              <div class="text media-body">
                <h3>{{ services.services[3].name }}</h3>
                <p>{{ services.services[3].description }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row justify-content-center mb-5 pb-2">
      <div class="col-md-8 text-center heading-section ftco-animate">
        <h2 class="mb-4">{{ services.partnershipsHeading }}</h2>
        <p>{{ services.partnershipsIntro }}</p>
      </div>
    </div>
    <div class="container">
      <div class="row">
        {% for partner in services.partners %}
        <div class="col-md-4">
          <div class="project mb-4 img ftco-animate d-flex justify-content-center align-items-center" style="background-image: url(/{{ partner.image }});">
            <div class="overlay"></div>
            <a href="{{ partner.url }}" class="btn-site d-flex align-items-center justify-content-center"><span class="icon-subdirectory_arrow_right"></span></a>
            <div class="text text-center p-4">
              <h3><a href="{{ partner.url }}">{{ partner.description }}</a></h3>
              <span>Click For More</span>
            </div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
