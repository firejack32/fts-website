---
layout: base.njk
title: Home
activePage: home
---

<section class="home-slider owl-carousel">
  {% for slide in site.homepage.slides %}
  <div class="slider-item" style="background-image:url(/{{ slide.backgroundImage }});">
    <div class="overlay"></div>
    <div class="container">
      <div class="row no-gutters slider-text align-items-center justify-content-start" data-scrollax-parent="true">
      <div class="col-md-7 ftco-animate">
        <span class="subheading">{{ slide.subtitle }}</span>
        <h1 class="mb-4">{{ slide.title }}</h1>
        <p><a href="{{ slide.buttonLink }}" class="btn btn-primary px-4 py-3 mt-3">{{ slide.buttonText }}</a></p>
      </div>
    </div>
    </div>
  </div>
  {% endfor %}
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row d-flex">
      <div class="col-md-5 order-md-last wrap-about align-items-stretch">
        <div class="wrap-about-border ftco-animate">
          <div class="img" style="background-image: url(/images/logo.png); border"></div>
          <div class="text">
            <h3>{{ site.homepage.aboutSection.heading }}</h3>
            <p>{{ site.homepage.aboutSection.description }}</p>
            <p>{{ site.homepage.aboutSection.subtext }}</p>
            <p align="center"><a href="/contact/" class="btn btn-primary py-3 px-4">Contact us</a></p>
          </div>
        </div>
      </div>

      <div class="col-md-7 wrap-about pr-md-4 ftco-animate">
        <h2 class="mb-4">{{ site.homepage.servicesHeading }}</h2>
        <p align="center">{{ site.homepage.servicesSubtext }}</p>
        <div class="row mt-5">
          <div class="col-lg-6">
            <div class="services active text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-analysis"></span></div>
              <div class="text media-body">
                <h3>{{ site.homepage.services[0].name }}</h3>
                <p>{{ site.homepage.services[0].brands }}</p>
              </div>
            </div>
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-business"></span></div>
              <div class="text media-body">
                <h3>{{ site.homepage.services[1].name }}</h3>
                <p>{{ site.homepage.services[1].brands }}</p>
              </div>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-search-engine"></span></div>
              <div class="text media-body">
                <h3>{{ site.homepage.services[2].name }}</h3>
                <p>{{ site.homepage.services[2].brands }}</p>
              </div>
            </div>
            <div class="services text-center">
              <div class="icon mt-2 d-flex justify-content-center align-items-center"><span class="flaticon-handshake"></span></div>
              <div class="text media-body">
                <h3>{{ site.homepage.services[3].name }}</h3>
                <p>{{ site.homepage.services[3].brands }}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ftco-intro ftco-no-pb img" style="background-image: url(/images/bg_3.jpg);">
  <div class="container">
    <div class="row justify-content-center mb-5">
      <div class="col-md-10 text-center heading-section heading-section-white ftco-animate">
        <h2 class="mb-0">{{ site.homepage.bannerText }}</h2>
      </div>
    </div>
  </div>
</section>

<section class="ftco-counter" id="section-counter">
  <div class="container">
    <div class="row d-md-flex align-items-center justify-content-center">
      <div class="wrapper">
        <div class="row d-md-flex align-items-center">
          {% for stat in site.homepage.stats %}
          <div class="col-md d-flex justify-content-center counter-wrap ftco-animate">
            <div class="block-18">
              <div class="icon"><span class="flaticon-doctor"></span></div>
              <div class="text">
                <strong class="number" data-number="{{ stat.number }}">0</strong>
                <span>{{ stat.label }}</span>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section ftco-consult ftco-no-pt ftco-no-pb" style="background-image: url(/images/bg_5.jpg);" data-stellar-background-ratio="0.5">
  <div class="overlay"></div>
  <div class="container">
    <div class="row justify-content-end">
      <div class="col-md-6 py-5 px-md-5">
        <div class="py-md-5">
          <div class="heading-section heading-section-white ftco-animate mb-5">
            <h2 align="center" class="mb-4">{{ site.homepage.quoteSection.heading }}</h2>
            <p align="center">{{ site.homepage.quoteSection.description }}</p>
          </div>
          <p align="center"><a href="mailto:{{ site.company.email }}?subject=Quote Request"><input type="submit" value="Request A Quote" class="btn btn-white py-3 px-4"></a></p>
        </div>
      </div>
    </div>
  </div>
</section>
